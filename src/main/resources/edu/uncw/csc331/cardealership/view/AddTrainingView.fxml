<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.dogtrainingapp.dog_training_app.controller.AddTrainingController"
      style="-fx-padding: 20;">
    <children>
        <Label text="Add Training Record" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <GridPane hgap="10" vgap="10">
            <children>
                <Label text="Dog ID:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="dogIdField" promptText="Enter dog ID" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                <Label text="Skill:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="skillField" promptText="Examples: Sit, Track" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                <Label text="Date:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="dateField" promptText="YYYY-MM-DD" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                <Label text="Performance:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <ComboBox fx:id="performanceComboBox" prefWidth="220" GridPane.rowIndex="3" GridPane.columnIndex="1" />
            </children>
        </GridPane>
        <GridPane hgap="10">
            <children>
                <Button text="Add Record" onAction="#addRecord" GridPane.columnIndex="0" />
                <Button text="Clear" onAction="#clearFields" GridPane.columnIndex="1" />
            </children>
        </GridPane>
        <Label fx:id="messageLabel" wrapText="true" style="-fx-text-fill: #8b0000;" />
    </children>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
</VBox>
