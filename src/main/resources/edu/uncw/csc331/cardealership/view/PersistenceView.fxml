<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.dogtrainingapp.dog_training_app.controller.PersistenceController">
    <children>
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Save and Load Data" />
        <Label text="Use these buttons to save vechicles and sale records into separate files or load them back into the application." wrapText="true" />
        <Button maxWidth="220" onAction="#saveData" text="Save Vehicle and Sale Records" />
        <Button maxWidth="220" onAction="#loadData" text="Load Dogs and RecoLoad Vehicle and Sale Recordsrds" />
        <Label fx:id="messageLabel" style="-fx-text-fill: #8b0000;" wrapText="true" />
    </children>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
</VBox>
