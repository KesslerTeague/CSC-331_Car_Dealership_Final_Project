<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.dogtrainingapp.dog_training_app.controller.BehaviorController"
      style="-fx-padding: 20;">
    <children>
        <Label text="Trigger Dog Behaviors" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <GridPane hgap="10" vgap="10">
            <children>
                <Label text="Dog ID:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="dogIdField" promptText="Enter dog ID" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                <Button text="Speak" onAction="#makeDogSpeak" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                <Button text="Perform Trick" onAction="#performTrick" GridPane.rowIndex="0" GridPane.columnIndex="3" />
            </children>
        </GridPane>
        <TextArea fx:id="outputArea" editable="false" prefHeight="250" promptText="Behavior output will appear here." wrapText="true" />
        <Label fx:id="messageLabel" wrapText="true" style="-fx-text-fill: #8b0000;" />
    </children>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
</VBox>
