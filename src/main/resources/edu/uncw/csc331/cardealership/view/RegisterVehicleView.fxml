<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.dogtrainingapp.dog_training_app.controller.RegisterDogController"
      style="-fx-padding: 20;">
    <children>
        <Label text="Register a Dog" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <GridPane hgap="10" vgap="10">
            <children>
                <Label text="Dog ID:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="idField" promptText="Enter numeric ID" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                <Label text="Name:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="nameField" promptText="Enter name" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                <Label text="Age:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="ageField" promptText="Enter age" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                <Label text="Breed:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="breedField" promptText="Enter breed" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                <Label text="Type:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <ComboBox fx:id="typeComboBox" prefWidth="220" GridPane.rowIndex="4" GridPane.columnIndex="1" />
            </children>
        </GridPane>
        <GridPane hgap="10">
            <children>
                <Button text="Register" onAction="#registerDog" GridPane.columnIndex="0" />
                <Button text="Clear" onAction="#clearFields" GridPane.columnIndex="1" />
            </children>
        </GridPane>
        <Label fx:id="messageLabel" wrapText="true" style="-fx-text-fill: #8b0000;" />
    </children>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
</VBox>
