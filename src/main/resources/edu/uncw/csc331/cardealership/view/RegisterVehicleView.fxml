<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.uncw.csc331.cardealership.controller.RegisterVehicleController">
    <children>
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Register a Vehicle" />
        <GridPane hgap="10" vgap="10">
            <children>
                <Label text="VIN:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="vinField" promptText="Enter numeric ID" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Label text="Make:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="makeField" promptText="Enter make" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Label text="Model:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="modelField" promptText="Enter model" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Label text="Year:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="yearField" promptText="Enter year" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <Label text="Price:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="priceField" promptText="Enter price" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <ComboBox fx:id="typeComboBox" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                <!-- Car-specific fields (hidden until Car is selected) -->
                <Label fx:id="numDoorsLabel" text="Doors:" visible="false" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <TextField fx:id="numDoorsField" promptText="Enter number of doors" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                <Label fx:id="bodyStyleLabel" text="Body Style:" visible="false" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                <TextField fx:id="bodyStyleField" promptText="e.g. Sedan, SUV, Coupe" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                <!-- Truck-specific fields (hidden until Truck is selected) -->
                <Label fx:id="cabStyleLabel" text="Cab Style:" visible="false" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <TextField fx:id="cabStyleField" promptText="e.g. Crew Cab, Regular Cab" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                <Label fx:id="cargoCapacityLabel" text="Cargo Capacity:" visible="false" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                <TextField fx:id="cargoCapacityField" promptText="Enter cargo capacity" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="7" />
            </children>
            <columnConstraints>
                <ColumnConstraints />
                <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints minHeight="10.0" prefHeight="30.0" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" />
            </rowConstraints>
        </GridPane>
        <GridPane hgap="10">
            <children>
                <Button onAction="#registerVehicle" text="Register" GridPane.columnIndex="0" />
                <Button onAction="#clearFields" text="Clear" GridPane.columnIndex="1" />
            </children>
            <columnConstraints>
                <ColumnConstraints />
                <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints />
            </rowConstraints>
        </GridPane>
        <Label fx:id="messageLabel" style="-fx-text-fill: #8b0000;" wrapText="true" />
    </children>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
</VBox>
